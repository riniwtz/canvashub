# Server-side DLSU Canvas course discovery headers.
CANVAS_COURSES_ACCEPT="text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8"
CANVAS_COURSES_CONNECTION="keep-alive"
CANVAS_COURSES_USER_AGENT="Mozilla/5.0 (Macintosh; Intel Mac OS X 10.15; rv:152.0) Gecko/20100101 Firefox/152.0"
CANVAS_COURSES_COOKIE=""
